{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KKCoder",
  "version": "0.1.0",
  "identifier": "com.kkcoder.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1435",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KKCoder 极简 AI 终端管理器",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 750,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
